# WolfArena AI local environment

APP_ENV=local
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Third-party OpenAI-compatible relay API.
LLM_BASE_URL=https://your-relay.example.com/v1
LLM_API_KEY=sk-your-relay-key
LLM_MODEL=your-model-name
LLM_TIMEOUT_SECONDS=60


# Frontend
# 前端调用后端 API 的基础地址。VITE_ 前缀会使该变量在前端构建时可用。
VITE_API_BASE_URL=http://localhost:8000

# 数据库与缓存
DATABASE_URL=postgresql+asyncpg://wolf_user:wolf_password@postgres:5432/wolf_game
REDIS_URL=redis://redis:6379/0

# 认证配置
AUTH_SECRET_KEY=change-me # JWT 或其他认证签名的密钥
AUTH_ACCESS_TOKEN_MINUTES=30 # 访问令牌过期时间，单位分钟数
AUTH_REFRESH_TOKEN_DAYS=30 # 刷新令牌过期时间，单位天数
AUTH_COOKIE_SECURE=true # 是否仅在 HTTPS 上发送认证令牌
AUTH_COOKIE_SAMESITE=lax # 认证令牌的 SameSite 属性值，防止跨站请求伪造

# 邮箱配置
EMAIL_CODE_TTL_SECONDS=300 # 验证码过期时间，单位秒数
EMAIL_CODE_COOLDOWN_SECONDS=60 # 验证码发送冷却时间，单位秒数
EMAIL_CODE_DAILY_LIMIT=10 # 每天发送的验证码数量限制
EMAIL_CODE_FAIL_LIMIT=5 # 连续失败次数限制
EMAIL_CODE_FAIL_TTL_SECONDS=900 # 连续失败后，等待时间，单位秒数    

# 阿里云邮箱配置
# 阿里云邮件推送的访问凭据
ALIYUN_MAIL_ACCESS_KEY_ID=你的AccessKeyId
ALIYUN_MAIL_ACCESS_KEY_SECRET=你的AccessKeySecret

ALIYUN_MAIL_ACCOUNT_NAME=你的邮箱账号名称
ALIYUN_MAIL_FROM_ALIAS=发送邮件的显示名称
ALIYUN_MAIL_ENDPOINT=https://dm.aliyuncs.com/ # 阿里云邮件推送的 API 端点
AUTH_SECRET_KEY=一串随机长密钥